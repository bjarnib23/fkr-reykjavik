<?php
                                                                                                          
  /**
   * @file
   * FKR Booking module hooks.
   */

  /**
   * Implements hook_mail().
   */
  function fkr_booking_mail($key, &$message, $params) {
    switch ($key) {
      case 'booking_confirmation':
        $message['from'] = \Drupal::config('system.site')->get('mail');
        $message['subject'] = t('Booking confirmation — FKR Reykjavík');
        $message['body'][] = t('Hello @name,', ['@name' => $params['name']]);
        $message['body'][] = t('We have received your booking request for @date. We will be in touch
  shortly to confirm your appointment.', ['@date' => $params['date']]);
        $message['body'][] = t('Thank you for choosing FKR Reykjavík.');
        break;
                  
      case 'booking_notification':
        $message['from'] = \Drupal::config('system.site')->get('mail');
        $message['subject'] = t('New booking request — @name', ['@name' => $params['name']]);
        $message['body'][] = t('A new booking request has been submitted.');
        $message['body'][] = t('Name: @name', ['@name' => $params['name']]);
        $message['body'][] = t('Email: @email', ['@email' => $params['email']]);
        $message['body'][] = t('Phone: @phone', ['@phone' => $params['phone']]);
        $message['body'][] = t('Date: @date', ['@date' => $params['date']]);
        $message['body'][] = t('Item: @item', ['@item' => $params['hvad_viltu_panta'] ?? '']);
        $message['body'][] = t('Notes: @notes', ['@notes' => $params['notes'] ?? '']);
        break;
    }
  }